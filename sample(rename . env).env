# Telegram Bot Configuration
# Copy this file to .env and fill in your actual values

# Bot Token from @BotFather (REQUIRED - get from https://t.me/BotFather)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Telegram API Credentials (from https://my.telegram.org)
API_ID=29868868
API_HASH=6b7bd10846ff6d7e8f50a4bfe13c9fd4

# Owner and Admin User IDs (comma-separated for multiple admins)
OWNER_ID=5884953489
ADMIN_IDS=5884953489

# Subscription Group Settings
SUBSCRIPTION_GROUP_ID=-1002605917246
SUBSCRIPTION_GROUP_NAME=Premium Channel

# Logs Channel (for payment receipts and renewal logs)
LOGS_CHANNEL_ID=

# Database Settings
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=tg_subs

# Payment Settings
CURRENCY=₹
PAYMENT_PROOF_REQUIRED=true

# Auto-approval settings
AUTO_APPROVE_VOUCHERS=true
AUTO_APPROVE_GIFTCARDS=true

# Bot Behavior
PAYMENT_TIMEOUT=300
MESSAGE_DELETE_TIMEOUT=120

# Base URL for webhooks (if needed)
BASE_URL=https://your-app-url.com